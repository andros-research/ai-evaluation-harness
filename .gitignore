# ---- Python / Conda ----
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints/
*.egg-info/
dist/
build/

# ---- VSCode / OS ----
.vscode/
.DS_Store

# ---- Secrets / keys ----
.env
*.key
*.pem

# ---- Model / run artifacts (IMPORTANT) ----
benchmarks/results_*/
benchmarks/**/results_*/
**/results_*/

# Raw response corpora can be huge—keep local by default
**/responses.jsonl
**/responses.json
**/responses/*.jsonl

# Optional: keep sample data only
data/

# ---- Additional generated benchmark artifacts ----
benchmarks/results/raw_runs/
benchmarks/results/aggregated/
benchmarks/results/narratives/

# ---- Local scratch / optional dirs ----
models/
notebooks/

# ---- Keep curated docs/images tracked ----
!docs/images/
!docs/images/*.png
!docs/images/*.jpg
!docs/images/*.jpeg